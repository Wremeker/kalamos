{
  "name": "kalamos-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source Notion-style block editor with a document storage backend",
  "license": "MIT",
  "packageManager": "yarn@4.10.3",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "yarn workspaces foreach -At --include '@kalamoss/*' --include 'server' --include 'demo' run build",
    "build:editor": "yarn workspace @kalamoss/editor run build",
    "typecheck": "yarn workspaces foreach -At run typecheck",
    "test": "yarn workspaces foreach -At run test",
    "dev:server": "yarn workspace server run dev",
    "dev:demo": "yarn workspace demo run dev"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "resolutions": {
    "@types/koa": "2.15.0"
  }
}
