# Server
PORT=4000
PUBLIC_BASE_URL=http://localhost:4000
# Comma-separated list of allowed CORS origins (use * to allow all in dev)
CORS_ORIGIN=http://localhost:5173

# Optional bearer-token guard. When set, all /api requests must send
# `Authorization: Bearer <API_TOKEN>`. Leave empty to disable (default).
API_TOKEN=

# Database
# DB_DIALECT: postgres (default) | sqlite (handy for local/dev/test)
DB_DIALECT=postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/block_editor
# For sqlite, the file path (DB_DIALECT=sqlite):
SQLITE_STORAGE=./data/dev.sqlite

# Storage driver: local (default) | s3
STORAGE_DRIVER=local
UPLOAD_DIR=./uploads

# S3 settings (only when STORAGE_DRIVER=s3)
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=false
